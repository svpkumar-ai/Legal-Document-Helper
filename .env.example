# Legal Document Helper — configuration
#
# Copy this file to `.env` for local development, then fill in your key.
# `.env` is git-ignored and is NEVER committed. On Vercel, set these as
# encrypted Environment Variables in the project settings instead of a file.

# REQUIRED — your Anthropic API key. The app reads it from the environment only;
# it is never hard-coded. Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional — port for local dev (ignored on Vercel).
PORT=3000

# Optional — override the model. Defaults to claude-opus-4-8.
# ANTHROPIC_MODEL=claude-opus-4-8
